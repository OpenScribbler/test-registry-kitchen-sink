{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Linting modified files...'",
            "timeout": 15000,
            "statusMessage": "Running linter...",
            "async": true
          }
        ]
      }
    ]
  }
}
